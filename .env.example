# Optional: copy this file to .env and fill in values.
# .env is ignored by git so secrets stay local.

# Email reports after each submission (leave unset to disable)
REPORT_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# SMTP_FROM=optional-sender@example.com
